<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mariam Audu Mshelia | Medical Virtual Assistant Portfolio</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --teal: #1D9E75;
    --teal-light: #E1F5EE;
    --teal-dark: #0F6E56;
    --gold: #BA7517;
    --gold-light: #FAEEDA;
    --navy: #042C53;
    --navy-mid: #185FA5;
    --cream: #FAFAF7;
    --white: #ffffff;
    --gray-text: #5F5E5A;
    --gray-light: #F1EFE8;
    --border: rgba(0,0,0,0.08);
    --shadow: 0 4px 24px rgba(0,0,0,0.07);
    --shadow-lg: 0 12px 48px rgba(0,0,0,0.12);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: #2C2C2A;
    line-height: 1.7;
  }
  nav {
    position: fixed; top: 0; width: 100%; z-index: 100;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 0 5%;
    display: flex; align-items: center; justify-content: space-between;
    height: 64px;
  }
  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 20px; font-weight: 700;
    color: var(--teal-dark);
    letter-spacing: -0.5px;
  }
  .nav-links { display: flex; gap: 32px; }
  .nav-links a {
    text-decoration: none; font-size: 14px; font-weight: 500;
    color: var(--gray-text);
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--teal); }
  .nav-cta {
    background: var(--teal);
    color: white !important;
    padding: 8px 20px;
    border-radius: 100px;
    font-size: 14px !important;
    font-weight: 600 !important;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
  }
  .nav-cta:hover { background: var(--teal-dark) !important; transform: translateY(-1px); }
  .hero {
    min-height: 100vh;
    padding: 100px 5% 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 80px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .hero-text h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(38px, 5vw, 60px);
    font-weight: 700;
    line-height: 1.1;
    color: var(--navy);
    margin-bottom: 8px;
  }
  .hero-text h1 span { color: var(--teal); }
  .hero-subtitle {
    font-size: 17px; font-weight: 500;
    color: var(--teal-dark);
    letter-spacing: 0.3px;
    margin-bottom: 20px;
  }
  .hero-text p {
    font-size: 16px; color: var(--gray-text);
    line-height: 1.8; margin-bottom: 32px;
    max-width: 480px;
  }
  .hero-badges {
    display: flex; flex-wrap: wrap; gap: 10px;
    margin-bottom: 36px;
  }
  .badge {
    background: var(--teal-light);
    color: var(--teal-dark);
    font-size: 13px; font-weight: 500;
    padding: 6px 14px; border-radius: 100px;
    border: 1px solid rgba(29,158,117,0.2);
  }
  .badge.gold {
    background: var(--gold-light);
    color: var(--gold);
    border-color: rgba(186,117,23,0.2);
  }
  .hero-ctas { display: flex; gap: 14px; flex-wrap: wrap; }
  .btn-primary {
    background: var(--teal);
    color: white;
    padding: 14px 28px;
    border-radius: 100px;
    text-decoration: none;
    font-weight: 600; font-size: 15px;
    transition: all 0.2s;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .btn-primary:hover { background: var(--teal-dark); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(29,158,117,0.25); }
  .btn-outline {
    border: 2px solid var(--teal);
    color: var(--teal);
    padding: 12px 28px;
    border-radius: 100px;
    text-decoration: none;
    font-weight: 600; font-size: 15px;
    transition: all 0.2s;
  }
  .btn-outline:hover { background: var(--teal-light); }
  .hero-image {
    display: flex; flex-direction: column; align-items: center; gap: 20px;
  }
  .avatar-frame {
    width: 300px; height: 300px;
    border-radius: 60% 40% 55% 45% / 45% 55% 45% 55%;
    background: linear-gradient(135deg, var(--teal-light), #9FE1CB);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
    position: relative;
    border: 4px solid var(--teal);
    box-shadow: var(--shadow-lg);
  }
  .avatar-initials {
    font-family: 'Playfair Display', serif;
    font-size: 80px;
    font-weight: 700;
    color: var(--teal-dark);
    opacity: 0.7;
  }
  .stats-row { display: flex; gap: 20px; }
  .stat-pill {
    background: white;
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 14px 20px;
    text-align: center;
    box-shadow: var(--shadow);
  }
  .stat-pill .num {
    font-size: 24px; font-weight: 700;
    color: var(--teal);
    font-family: 'Playfair Display', serif;
  }
  .stat-pill .lbl { font-size: 12px; color: var(--gray-text); font-weight: 500; }
  section { padding: 80px 5%; max-width: 1200px; margin: 0 auto; }
  .section-label {
    font-size: 12px; font-weight: 600;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 10px;
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 700;
    color: var(--navy);
    line-height: 1.2;
    margin-bottom: 16px;
  }
  .section-desc { font-size: 16px; color: var(--gray-text); max-width: 600px; margin-bottom: 48px; }
  .divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--teal), transparent);
    margin: 0 5%;
    opacity: 0.25;
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }
  .service-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 32px;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    cursor: default;
  }
  .service-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
  .service-card::before {
    content: '';
    position: absolute; top: 0; left: 0;
    width: 4px; height: 100%;
    background: var(--teal);
  }
  .service-card.gold-accent::before { background: var(--gold); }
  .service-card.navy-accent::before { background: var(--navy-mid); }
  .service-icon {
    width: 48px; height: 48px;
    background: var(--teal-light);
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 24px;
    margin-bottom: 20px;
  }
  .service-card.gold-accent .service-icon { background: var(--gold-light); }
  .service-card.navy-accent .service-icon { background: #E6F1FB; }
  .service-card h3 {
    font-size: 18px; font-weight: 600;
    color: var(--navy);
    margin-bottom: 12px;
    font-family: 'Playfair Display', serif;
  }
  .service-card p { font-size: 14px; color: var(--gray-text); line-height: 1.7; }
  .service-tools { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 16px; }
  .tool-tag {
    background: var(--gray-light);
    color: var(--gray-text);
    font-size: 11px; font-weight: 500;
    padding: 3px 10px; border-radius: 100px;
  }
  .timeline { position: relative; padding-left: 32px; }
  .timeline::before {
    content: '';
    position: absolute; left: 8px; top: 8px; bottom: 8px;
    width: 2px;
    background: linear-gradient(to bottom, var(--teal), var(--teal-light));
  }
  .timeline-item {
    position: relative;
    margin-bottom: 40px;
    background: white;
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px;
  }
  .timeline-item::before {
    content: '';
    position: absolute; left: -40px; top: 32px;
    width: 14px; height: 14px;
    background: var(--teal);
    border-radius: 50%;
    border: 3px solid var(--cream);
    box-shadow: 0 0 0 2px var(--teal);
  }
  .job-header {
    display: flex; justify-content: space-between; align-items: flex-start;
    flex-wrap: wrap; gap: 8px;
    margin-bottom: 16px;
  }
  .job-title { font-size: 17px; font-weight: 600; color: var(--navy); }
  .job-company { font-size: 14px; font-weight: 500; color: var(--teal-dark); margin-top: 2px; }
  .job-date {
    background: var(--teal-light);
    color: var(--teal-dark);
    font-size: 12px; font-weight: 600;
    padding: 4px 12px; border-radius: 100px;
    white-space: nowrap;
  }
  .job-duties { list-style: none; padding: 0; }
  .job-duties li {
    font-size: 14px; color: var(--gray-text);
    padding: 4px 0 4px 20px;
    position: relative;
    line-height: 1.6;
  }
  .job-duties li::before {
    content: '▸';
    position: absolute; left: 0;
    color: var(--teal);
    font-size: 12px;
  }
  .samples-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
  }
  .sample-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .sample-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
  .sample-preview {
    height: 160px;
    display: flex; align-items: center; justify-content: center;
    font-size: 48px;
    position: relative;
    overflow: hidden;
  }
  .sample-preview.teal-bg { background: linear-gradient(135deg, #E1F5EE, #9FE1CB); }
  .sample-preview.gold-bg { background: linear-gradient(135deg, #FAEEDA, #FAC775); }
  .sample-preview.navy-bg { background: linear-gradient(135deg, #E6F1FB, #B5D4F4); }
  .sample-preview.coral-bg { background: linear-gradient(135deg, #FAECE7, #F5C4B3); }
  .sample-preview.green-bg { background: linear-gradient(135deg, #EAF3DE, #C0DD97); }
  .sample-preview.purple-bg { background: linear-gradient(135deg, #EEEDFE, #CECBF6); }
  .sample-label {
    position: absolute; bottom: 10px; left: 10px;
    font-size: 10px; font-weight: 600; letter-spacing: 1px;
    text-transform: uppercase; color: var(--teal-dark);
    background: rgba(255,255,255,0.9); padding: 3px 10px; border-radius: 100px;
  }
  .sample-body { padding: 24px; }
  .sample-body h3 {
    font-size: 16px; font-weight: 600;
    color: var(--navy);
    margin-bottom: 8px;
    font-family: 'Playfair Display', serif;
  }
  .sample-body p { font-size: 13px; color: var(--gray-text); line-height: 1.6; margin-bottom: 14px; }
  .sample-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .sample-tag {
    background: var(--teal-light);
    color: var(--teal-dark);
    font-size: 11px; font-weight: 500;
    padding: 3px 10px; border-radius: 100px;
  }
  .skills-section-bg {
    background: var(--navy);
    padding: 80px 5%;
    margin: 0;
  }
  .skills-section-bg .section-label { color: #9FE1CB; }
  .skills-section-bg .section-title { color: white; }
  .skills-section-bg .section-desc { color: rgba(255,255,255,0.6); }
  .skills-container { max-width: 1200px; margin: 0 auto; }
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 16px;
  }
  .skill-item {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    padding: 18px 20px;
    display: flex; align-items: center; gap: 12px;
    transition: background 0.2s;
    cursor: default;
  }
  .skill-item:hover { background: rgba(29,158,117,0.15); border-color: var(--teal); }
  .skill-dot { width: 8px; height: 8px; background: var(--teal); border-radius: 50%; flex-shrink: 0; }
  .skill-item span { font-size: 14px; color: rgba(255,255,255,0.85); font-weight: 400; }
  .edu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }
  .edu-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
    display: flex; gap: 16px;
    transition: box-shadow 0.2s;
  }
  .edu-card:hover { box-shadow: var(--shadow); }
  .edu-icon {
    width: 42px; height: 42px;
    background: var(--teal-light);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; flex-shrink: 0;
  }
  .edu-icon.gold { background: var(--gold-light); }
  .edu-body h4 { font-size: 14px; font-weight: 600; color: var(--navy); line-height: 1.4; margin-bottom: 4px; }
  .edu-body p { font-size: 12px; color: var(--gray-text); }
  .edu-date { font-size: 11px; font-weight: 600; color: var(--teal); margin-top: 6px; display: block; }
  .tools-grid { display: flex; flex-wrap: wrap; gap: 12px; }
  .tool-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 12px 20px;
    font-size: 14px; font-weight: 500;
    color: var(--navy);
    display: flex; align-items: center; gap: 10px;
    transition: all 0.2s;
  }
  .tool-card:hover { border-color: var(--teal); color: var(--teal-dark); background: var(--teal-light); }
  .tool-card .icon { font-size: 18px; }
  .award-banner {
    background: linear-gradient(135deg, var(--navy), var(--navy-mid));
    border-radius: 20px;
    padding: 40px;
    display: flex; align-items: center; gap: 32px;
    color: white;
    margin-bottom: 48px;
  }
  .award-icon { font-size: 60px; flex-shrink: 0; }
  .award-text h3 { font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; margin-bottom: 8px; }
  .award-text p { font-size: 15px; opacity: 0.8; }
  .contact-section { background: var(--teal-dark); padding: 80px 5%; text-align: center; }
  .contact-inner { max-width: 700px; margin: 0 auto; }
  .contact-section .section-label { color: #9FE1CB; justify-content: center; display: block; }
  .contact-section .section-title { color: white; text-align: center; }
  .contact-section p { color: rgba(255,255,255,0.7); font-size: 17px; margin-bottom: 40px; }
  .contact-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 16px; margin-bottom: 40px; }
  .contact-chip {
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    color: white;
    padding: 12px 24px;
    border-radius: 100px;
    font-size: 15px;
    text-decoration: none;
    display: flex; align-items: center; gap: 8px;
    transition: background 0.2s;
  }
  .contact-chip:hover { background: rgba(255,255,255,0.2); }
  .availability-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(29,158,117,0.3);
    border: 1px solid rgba(29,158,117,0.5);
    color: #9FE1CB;
    padding: 8px 20px; border-radius: 100px;
    font-size: 14px; font-weight: 500;
  }
  .green-dot {
    width: 8px; height: 8px;
    background: #5DCAA5;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  footer {
    background: var(--navy);
    color: rgba(255,255,255,0.5);
    text-align: center;
    padding: 24px;
    font-size: 13px;
  }
  footer a { color: #9FE1CB; text-decoration: none; }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .fade-up { animation: fadeUp 0.7s ease forwards; }
  .fade-up:nth-child(2) { animation-delay: 0.1s; }
  .fade-up:nth-child(3) { animation-delay: 0.2s; }
  .fade-up:nth-child(4) { animation-delay: 0.3s; }
  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; gap: 40px; padding-top: 80px; text-align: center; }
    .hero-text p { margin: 0 auto 32px; }
    .hero-badges { justify-content: center; }
    .hero-ctas { justify-content: center; }
    .hero-image { order: -1; }
    .avatar-frame { width: 200px; height: 200px; }
    .avatar-initials { font-size: 52px; }
    .nav-links { display: none; }
    .award-banner { flex-direction: column; text-align: center; }
  }
</style>
</head>
